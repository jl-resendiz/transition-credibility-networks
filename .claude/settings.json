{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/pre_commit_check.py",
            "timeout": 10,
            "statusMessage": "Checking for orphan scripts..."
          }
        ]
      }
    ]
  }
}

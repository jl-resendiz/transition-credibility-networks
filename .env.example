# Replication-package credentials.
#
# Copy this file to `.env` and fill in your own values. The `.env` file is
# gitignored. Do NOT commit credentials.
#
#   cp .env.example .env
#
# Scripts in `src/` that need credentials read them through
# `src/_credentials.py`, which loads this file automatically.

# ─── WRDS (Wharton Research Data Services) ────────────────────────────
# Required for: pull_wrds_*.py (CRSP, Compustat, Thomson 13F holdings,
# DGTW characteristic data).
# How to obtain: see REPLICATION.md §"Obtaining credentials" or
# https://wrds-www.wharton.upenn.edu/register/
# Note: WRDS uses username + password (no API key). The `wrds` Python
# package can also read these from a ~/.pgpass file; either route works.

WRDS_USERNAME=
WRDS_PASSWORD=

# ─── LSEG Eikon / Refinitiv ────────────────────────────────────────────
# Required for: pull_eikon_returns.py, pull_refinitiv_esg.py,
# pull_refinitiv_extra.py, pull_refinitiv_panel.py.
# How to obtain: see REPLICATION.md §"Obtaining credentials". The Eikon
# API key is generated in the Eikon desktop application under
# "App Generator" -> "Register New App". The desktop app must be running
# while the pull scripts execute.

EIKON_APP_KEY=

# (Optional alias, used by older pull scripts.)
# REFINITIV_APP_KEY=
